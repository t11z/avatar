{
  "annotations": {
    "list": []
  },
  "editable": true,
  "schemaVersion": 39,
  "title": "avatar",
  "tags": ["avatar"],
  "timezone": "browser",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Up",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "up{job=\"avatar\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Posts (rate/5m)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 18,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (platform, result) (rate(avatar_posts_total[5m]))",
          "legendFormat": "{{platform}} {{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Trigger events (rate/5m)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum by (kind) (rate(avatar_triggers_total[5m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "LLM latency (p95)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, provider) (rate(avatar_llm_latency_seconds_bucket[5m])))",
          "legendFormat": "{{provider}} p95",
          "refId": "A"
        }
      ]
    }
  ]
}

# Copy to .env and fill in. Secrets are referenced from config.yaml via ${VAR}.
# Never commit your real .env.

# --- Model providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_HOST=http://localhost:11434

# --- Platforms ---
# Bluesky (app password recommended)
BLUESKY_HANDLE=your-bot.bsky.social
BLUESKY_APP_PASSWORD=
# X / Twitter (requires a paid API tier for posting and reading mentions)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_BEARER_TOKEN=
# Threads (Meta Graph API)
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# --- Optional security scan hook (generic; any compatible service) ---
SCAN_API_TOKEN=
